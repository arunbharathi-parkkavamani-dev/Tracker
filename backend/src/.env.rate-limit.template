## Kubernetes Deployment

```yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: loigmax-rate-limit-config
data:
  RATE_LIMIT_PER_SECOND: "10"
  RATE_LIMIT_PER_MINUTE: "300"
  RATE_LIMIT_PER_HOUR: "3600"
  QUEUE_MAX_CONCURRENT_PER_DEVICE: "2"
  QUEUE_MAX_SIZE: "100"
  LOCK_TIMEOUT: "30000"

---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: loigmax-api
spec:
  template:
    spec:
      containers:
      - name: api
        image: loigmax/api:latest
        envFrom:
        - configMapRef:
            name: loigmax-rate-limit-config
        resources:
          requests:
            memory: "512Mi"
            cpu: "250m"
          limits:
            memory: "2Gi"
            cpu: "1000m"
```

## Docker Compose

```yaml
version: '3.8'
services:
  api:
    image: loigmax/api:latest
    environment:
      RATE_LIMIT_PER_SECOND: 10
      RATE_LIMIT_PER_MINUTE: 300
      QUEUE_MAX_CONCURRENT_PER_DEVICE: 2
